# OpenCode server port (default: 4096)
OPENCODE_SERVER_PORT=4096

# Workspace mount path (default: ./workspace)
OPENWORK_MOUNT_PATH=./workspace

# OpenWork settings
OPENWORK_APPROVAL=auto
OPENWORK_VERBOSE=1
OPENWORK_LOG_FORMAT=json
OPENWORK_SIDECAR_DIR=/home/openwork/.cache/openwork/sidecars
OPENWORK_OPENCODE_HOT_RELOAD=1
OPENWORK_OPENCODE_HOT_RELOAD_DEBOUNCE_MS=500
OPENWORK_OPENCODE_HOT_RELOAD_COOLDOWN_MS=1000